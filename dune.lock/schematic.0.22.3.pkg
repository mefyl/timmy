(version 0.22.3)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (dune
   base
   base64
   bytesrw
   ezjsonm
   fmt
   hlist
   hmap
   logs
   ocaml
   ppxlib
   ppx_deriving
   ppx_here
   ptime
   semver2
   uri)))

(source
 (fetch
  (url
   git+ssh://git@gitlab.routine.co/routine/schematic#8b94e36c10c000cbef03e67ce5dfd41595aed414)))

(dev)
