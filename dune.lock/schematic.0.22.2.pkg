(version 0.22.2)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (dune
   base
   base64
   bytesrw
   ezjsonm
   fmt
   hlist
   hmap
   logs
   ocaml
   ppxlib
   ppx_deriving
   ppx_here
   ptime
   semver2
   uri)))

(source
 (fetch
  (url
   git+ssh://git@gitlab.routine.co/routine/schematic#b832baad7f3a7c493f49e3a6fd8c0bb1721a8a38)))

(dev)
